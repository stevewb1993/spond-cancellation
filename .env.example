# Leave DATABASE_URL unset for local dev (uses a local SQLite file).
# In production set it to your Neon Postgres connection string.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

SPOND_USERNAME=your-spond-email@example.com
SPOND_PASSWORD=your-spond-password
SPOND_CLUB_ID=your-club-id
ADMIN_PASSWORD=choose-a-password
SECRET_KEY=change-this-to-something-random

# Verification codes are emailed via the Brevo HTTPS API (https://brevo.com).
# Create a free account, verify a sender address, and create an API key.
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=bathamphibiansbookings@gmail.com
EMAIL_FROM_NAME=Bath Amphibians
