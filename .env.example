# Leave DATABASE_URL unset for local dev (uses a local SQLite file).
# In production set it to your Neon Postgres connection string.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

SPOND_USERNAME=your-spond-email@example.com
SPOND_PASSWORD=your-spond-password
SPOND_CLUB_ID=your-club-id
ADMIN_PASSWORD=choose-a-password
SECRET_KEY=change-this-to-something-random

# Email used to send members their one-time verification codes.
# For Gmail, SMTP_PASSWORD must be a 16-char App Password (with 2FA enabled),
# NOT your normal account password. See: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=bathamphibiansbookings@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=bathamphibiansbookings@gmail.com
